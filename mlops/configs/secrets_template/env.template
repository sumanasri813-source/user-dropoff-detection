# Copy this file to .env and replace placeholders.
# Do not commit real secrets.

APP_ENV=dev
FLASK_ENV=development
ENABLE_SECURITY_HARDENING=false

# Application security
API_KEY=replace_with_api_key
SESSION_SECRET_KEY=replace_with_session_secret_key
JWT_SECRET_KEY=replace_with_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Infrastructure
DATABASE_URL=replace_with_database_url
MODEL_REGISTRY_TOKEN=replace_with_registry_token
ALERT_WEBHOOK_URL=replace_with_alert_webhook
