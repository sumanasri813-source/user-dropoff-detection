# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dropoff_detection
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600
DB_ECHO_SQL=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0

# Application Configuration
APP_ENV=development
APP_NAME=Dropoff Detection API
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-jwt-secret-key-here-change-in-production
SESSION_SECRET_KEY=your-session-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
API_KEY=your-api-key-for-protected-endpoints
ENABLE_SECURITY_HARDENING=false
FLASK_ENV=development

# API Server
API_HOST=0.0.0.0
API_PORT=8000
GUNICORN_WORKERS=4
GUNICORN_THREADS=2

# pgAdmin (for database admin)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# Feature Flags
ENABLE_CACHING=true
ENABLE_AUDIT_LOGGING=true
ENABLE_API_MONITORING=true
ENABLE_WEBSOCKET=false

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=8001

# S3/Cloud Storage (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# Email (for notifications)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
