    {
      "name": "Batch Prediction",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response is array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "    pm.expect(jsonData.length).to.equal(3);",
              "});",
              "pm.test(\"All predictions have required fields\", function () {",
              "    var jsonData = pm.response.json();",
              "    jsonData.forEach(function(pred) {",
              "        pm.expect(pred).to.have.property('prediction');",
              "        pm.expect(pred).to.have.property('probability');",
              "        pm.expect(pred).to.have.property('risk_level');",
              "    });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-API-Key",
            "value": "dev-local-key"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"predictions\": [\n    {\n      \"days_signup_age\": 500,\n      \"recency_days\": 5,\n      \"frequency_total\": 100,\n      \"session_duration_avg\": 45.0,\n      \"feature_count_used\": 14,\n      \"device_type\": \"desktop\",\n      \"os_type\": \"windows\",\n      \"user_segment\": \"premium\",\n      \"region\": \"north\"\n    },\n    {\n      \"days_signup_age\": 45,\n      \"recency_days\": 100,\n      \"frequency_total\": 5,\n      \"session_duration_avg\": 2.0,\n      \"feature_count_used\": 1,\n      \"device_type\": \"mobile\",\n      \"os_type\": \"android\",\n      \"user_segment\": \"free\",\n      \"region\": \"south\"\n    },\n    {\n      \"days_signup_age\": 200,\n      \"recency_days\": 30,\n      \"frequency_total\": 50,\n      \"session_duration_avg\": 20.0,\n      \"feature_count_used\": 8,\n      \"device_type\": \"tablet\",\n      \"os_type\": \"ios\",\n      \"user_segment\": \"trial\",\n      \"region\": \"east\"\n    }\n  ],\n  \"return_probabilities\": true\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:5000/predict-batch",
          "protocol": "http",
          "host": ["127", "0", "0", "1"],
          "port": "5000",
          "path": ["predict-batch"]
        }
      }
    },
