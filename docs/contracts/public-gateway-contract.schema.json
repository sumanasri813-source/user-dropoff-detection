{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/public-gateway-contract-v1.schema.json",
  "title": "Public Gateway Contract V1",
  "description": "Public API contract between frontend clients and production API gateway.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/PublicPredictRequest" },
    { "$ref": "#/$defs/PublicPredictSuccessResponse" },
    { "$ref": "#/$defs/PublicPredictErrorResponse" }
  ],
  "$defs": {
    "PublicPredictRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "user", "session", "features"],
      "properties": {
        "request_id": { "type": "string", "format": "uuid" },
        "user": {
          "type": "object",
          "additionalProperties": false,
          "required": ["user_id", "segment", "region"],
          "properties": {
            "user_id": { "type": "string", "minLength": 1 },
            "segment": { "type": "string", "enum": ["free", "trial", "premium"] },
            "region": { "type": "string", "enum": ["north", "south", "east", "west"] }
          }
        },
        "session": {
          "type": "object",
          "additionalProperties": false,
          "required": ["session_id", "timestamp_utc", "device_type", "os_type"],
          "properties": {
            "session_id": { "type": "string", "minLength": 1 },
            "timestamp_utc": { "type": "string", "format": "date-time" },
            "device_type": { "type": "string", "enum": ["mobile", "desktop", "tablet"] },
            "os_type": { "type": "string", "enum": ["android", "ios", "windows", "mac", "linux"] }
          }
        },
        "features": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "days_signup_age",
            "recency_days",
            "frequency_total",
            "session_duration_avg",
            "feature_count_used"
          ],
          "properties": {
            "days_signup_age": { "type": "number", "minimum": 0 },
            "recency_days": { "type": "number", "minimum": 0 },
            "frequency_total": { "type": "number", "minimum": 0 },
            "session_duration_avg": { "type": "number", "minimum": 0 },
            "feature_count_used": { "type": "number", "minimum": 0 }
          }
        },
        "context": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "source": { "type": "string" },
            "model_hint": { "type": "string" }
          }
        }
      }
    },
    "TopReason": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature", "impact"],
      "properties": {
        "feature": { "type": "string" },
        "impact": { "type": "number" }
      }
    },
    "PublicPredictSuccessResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "prediction", "model", "meta"],
      "properties": {
        "request_id": { "type": "string", "format": "uuid" },
        "prediction": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dropoff_probability", "risk_label", "predicted_label", "threshold_used"],
          "properties": {
            "dropoff_probability": { "type": "number", "minimum": 0, "maximum": 1 },
            "risk_label": { "type": "string", "enum": ["low", "medium", "high"] },
            "predicted_label": { "type": "integer", "enum": [0, 1] },
            "threshold_used": { "type": "number", "minimum": 0, "maximum": 1 },
            "top_reasons": {
              "type": "array",
              "items": { "$ref": "#/$defs/TopReason" }
            }
          }
        },
        "model": {
          "type": "object",
          "additionalProperties": false,
          "required": ["model_name", "model_version"],
          "properties": {
            "model_name": { "type": "string" },
            "model_version": { "type": "string" }
          }
        },
        "meta": {
          "type": "object",
          "additionalProperties": false,
          "required": ["inference_timestamp_utc", "latency_ms"],
          "properties": {
            "inference_timestamp_utc": { "type": "string", "format": "date-time" },
            "latency_ms": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "PublicPredictErrorResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "error"],
      "properties": {
        "request_id": { "type": "string", "format": "uuid" },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": {
              "type": "string",
              "enum": ["VALIDATION_ERROR", "UNAUTHORIZED", "UPSTREAM_ERROR", "INTERNAL_ERROR"]
            },
            "message": { "type": "string" },
            "details": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["field", "issue"],
                "properties": {
                  "field": { "type": "string" },
                  "issue": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
